# Signflo — environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; .env.example is committed as a template.

# Anthropic API — required for vision + generation
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# Local persistence (relative to repo root)
DATABASE_URL=./data/signflo.db
UPLOADS_DIR=./uploads

# Runtime mode
NODE_ENV=development
